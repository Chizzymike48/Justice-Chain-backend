# JusticeChain Environment Variables
# Copy to .env and update values

# Backend (REQUIRED)
JWT_SECRET=your-super-secure-jwt-secret-min32-chars-change-in-prod

# Backend (OPTIONAL - graceful fallback if missing)
MONGODB_URI=mongodb://localhost:27017/justicechain
# Set ENABLE_MONGO=false to disable DB features

# Optional: Redis cache
REDIS_URL=redis://localhost:6379
# Or: REDIS_HOST=localhost REDIS_PORT=6379 REDIS_PASSWORD=pass
# Set ENABLE_REDIS=false to disable

# Production streaming (REQUIRED in prod)
STREAM_INGEST_BASE_URL=https://your-ingest-server.com
STREAM_PLAYBACK_BASE_URL=https://your-playback-server.com

# Frontend (Vite)
VITE_API_URL=http://localhost:5000/api/v1
# In prod: VITE_API_URL=https://your-api-domain.com/api/v1

# Backend (CORS)
# Comma-separated list; supports wildcards like https://*.vercel.app
CORS_ORIGIN=http://localhost:5173
# Allow Vercel preview deployments (default true)
CORS_ALLOW_VERCEL_PREVIEWS=true

# Optional services
SENTRY_DSN=your-sentry-dsn
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
AWS_S3_BUCKET=your-bucket

# Disable validation in dev if testing
SKIP_ENV_VALIDATION=false
