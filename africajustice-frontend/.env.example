# ============================================================================
# JUSTICECHAIN FRONTEND - ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env or .env.local to version control
# ============================================================================

# VITE - API ENDPOINT
# Point to your backend server
VITE_API_URL=http://localhost:5000/api

# VITE - SENTRY ERROR TRACKING
# Get your DSN from: https://sentry.io/organizations/[org]/projects/[project]
VITE_SENTRY_DSN=
VITE_RELEASE_VERSION=1.0.0

# VITE - SOCKET.IO
# WebSocket connection URL
VITE_SOCKET_URL=http://localhost:5000

# Optional: Analytics, tracking, etc.
# VITE_ANALYTICS_ID=
# VITE_APP_NAME=JusticeChain
# VITE_APP_VERSION=1.0.0
